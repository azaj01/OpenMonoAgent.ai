# Models are mounted as volumes, not baked into images
models/

# Reference code is mounted as volume
ref/

# Build artifacts
**/bin/
**/obj/
**/node_modules/

# llama.cpp build artifacts (source is copied for Dockerfile.llama)
llama.cpp/build/

# Test project — not needed in either Dockerfile (legacy or ACP).
# Reduces the build context from ~10MB to ~2MB.
src/OpenMono.Tests/

# IDE and OS
.git/
.vs/
.vscode/
.idea/
*.swp
*Zone.Identifier

# Docs not needed in container
docs/
*.md
!OPENMONO.md

# Avoid recursive copy of our own Dockerfile / dockerignore into the image
Dockerfile
.dockerignore
