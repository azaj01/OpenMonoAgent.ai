# syntax=docker/dockerfile:1.6
#
# OpenMono agent image — two consumers:
#   1. VS Code extension (DockerManager) and `public/scripts/acp-smoke.sh`:
#      headless ACP server on 7475. Uses the default CMD (--acp-only).
#   2. `public/docker/docker-compose.yml` agent service:
#      interactive TUI on a mounted workspace. Overrides `command: []`
#      to clear the default CMD so `openmono` starts without --acp-only.
#
# Build from the `public/` directory:
#   docker build -f public/docker/Dockerfile.agent -t openmono/agent:dev public/

FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Solution-level files for restore layer caching.
COPY Directory.Build.props ./
COPY OpenMono.sln ./
COPY global.json ./

COPY src/OpenMono.Cli/OpenMono.Cli.csproj src/OpenMono.Cli/
RUN dotnet restore src/OpenMono.Cli/OpenMono.Cli.csproj

COPY src/OpenMono.Cli/ src/OpenMono.Cli/
RUN dotnet publish src/OpenMono.Cli/OpenMono.Cli.csproj \
    -c Release \
    -o /app \
    --no-restore \
    /p:UseAppHost=true

# ── Runtime ────────────────────────────────────────────────────────────────
# We need the SDK base because the agent's tools (Bash, Grep, ApplyPatch) shell
# out to git / ripgrep / patch / python and the slim aspnet image doesn't ship
# those.

FROM mcr.microsoft.com/dotnet/sdk:10.0 AS runtime
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    ripgrep \
    curl \
    jq \
    tree \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# HOME for the docker-compose TUI variant; compose mounts ~/.openmono here.
RUN mkdir -p /home/agent && chmod 1777 /home/agent

# MCP servers shipped with the agent (structural + semantic graph queries).
RUN pip3 install --no-cache-dir --break-system-packages code-review-graph graphifyy

COPY --from=build /app /usr/local/bin/openmono/
ENV PATH="/usr/local/bin/openmono:${PATH}"

# Sessions live in /data. ACP callers MUST mount a named volume here
# (e.g. `-v openmono-sessions-<agent_id>:/data`) for session JSON files to
# survive container removal. With `--rm` and an anonymous volume, session
# state is wiped on every container stop.
VOLUME ["/data"]

# Default workspace mount-point. ACP callers pass -v <host>:/workspace;
# the docker-compose service mounts ${WORKSPACE:-.} here.
WORKDIR /workspace

# ACP server port (used when --acp-only is active).
EXPOSE 7475
ENV ACP_PORT=7475 \
    ASPNETCORE_URLS=http://0.0.0.0:7475

# Default to ACP headless mode (the primary consumer is the extension).
# docker-compose's agent service overrides `command: []` to clear CMD and
# get the interactive TUI instead.
ENTRYPOINT ["openmono"]
CMD ["--acp-only"]
